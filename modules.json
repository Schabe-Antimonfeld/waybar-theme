{
    "custom/arch": {
        "format": "ˇ░úç",
        "tooltip": true,
        "tooltip-format": "Power menu",
        "menu": "on-click",
        "menu-file": "~/.config/waybar/power_menu.xml",
        "menu-actions": {
            "suspend": "systemctl suspend",
            "logout": "hyprctl dispatch exit",
            "reboot": "systemctl reboot",
            "shutdown": "systemctl poweroff"
        }
    },


    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "format-icons": {
            "urgent": "´ü¬",
            "active": "´ćĺ",
            "default": "´äĹ"
        }
    },
    "hyprland/window": {
        "max-length": 50,
        "separate-outputs": true
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },
    "tray": {
        "icon-size": 1,
        "spacing": 0
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon} {volume}% ´Őö {format_source}",
        "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
        "format-muted": "´Üę {format_source}",
        "format-source": "´ä░ {volume}%",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "on-click": "pavucontrol"
    },
    "custom/vpn": {
        "exec": "sh -c 'case \"$(gsettings get org.gnome.system.proxy mode 2>/dev/null)\" in \"'\\''manual'\\''\"|\"'\\''auto'\\''\") echo \"ˇ░ľé  VPN ON\" ;; *) echo \"ˇ░ľé  VPN OFF\" ;; esac'",
        "interval": 1,
        "format": "{}",
        "tooltip": true,
        "tooltip-format": "Clash Verge",
        "on-click": "python3 /home/schabe/.config/waybar/open_network_menu.py clash"
    },
    "network": {
        "format-wifi": "´çź   {essid} ({signalStrength}%)",
        "format-ethernet": "{ipaddr}/{cidr} ´×ľ",
        "tooltip-format": "{ifname} via {gwaddr} ´×ľ",
        "format-linked": "{ifname} (No IP) ´×ľ",
        "format-disconnected": "Disconnected ÔÜá",
        "on-click": "python3 /home/schabe/.config/waybar/open_network_menu.py"

    },
    "cpu": {
        "format": "´őŤ  {usage}%",
        "tooltip": true
    },
    "memory": {
        "format": "´âë  {}%",
	"tooltip": true
    },
    "temperature": {
        "interval": 10,
        "hwmon-path": "/sys/class/hwmon/hwmon4/temp1_input",
        "critical-threshold": 100,
        "format-critical": "´őç {temperatureC}",
        "format": "´őë {temperatureC}┬░C"
    },
    "custom/input": {
        "exec": "sh -c 'case \"$(fcitx5-remote -n)\" in rime) echo ńŞş ;; keyboard-us) echo EN ;; *) fcitx5-remote -n ;; esac'",
        "interval": 1,
        "format": "´éČ  {text}",
        "on-click": "sh -c 'current=$(fcitx5-remote -n); if [ \"$current\" = rime ]; then fcitx5-remote -s keyboard-us; else fcitx5-remote -s rime; fi'",
        "tooltip-format": "Fcitx5: {text}"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "´Śž  {capacity}%",
        "format-plugged": "´çŽ  {capacity}%",
        "format-alt": "{time}  {icon}",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
    "clock": {
        "format": "{:%H:%M | %e %B} ",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    }

}
